# Robinhood credentials
# RH_USERNAME=your_email
# RH_PASSWORD=your_password
# RH_TOTP_CODE=your_totp_secret
# RH_AUTOMATED_ACCOUNT_NUMBER=your_account_number

# Alpaca API keys (used by Scala market-data-service and fill auditor)
# Free tier gives IEX quotes (~2% market coverage)
# Paid tier ($99/mo) gives SIP NBBO (full market)
# ALPACA_API_KEY=your_key
# ALPACA_SECRET_KEY=your_secret

# Redis (used by market-data-service, blob unloader, and trading system)
# REDIS_HOST=redis-17054.c99.us-east-1-4.ec2.cloud.redislabs.com:17054
# REDIS_PASSWORD=your_redis_password

# Market Data Service (Scala poller)
# POLL_INTERVAL_MS=3000
# SYMBOLS=BTC
# CRYPTO_SYMBOLS=BTC/USD
# HISTORY_MAX_SIZE=10000

# Netlify Blobs (for state logging and market quote archival)
# NETLIFY_API_TOKEN=your_token
# NETLIFY_SITE_ID=your_site_id
